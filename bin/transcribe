#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"

find_bun() {
  if command -v bun >/dev/null 2>&1; then
    command -v bun
    return 0
  fi
  if [[ -x "$HOME/.bun/bin/bun" ]]; then
    printf '%s\n' "$HOME/.bun/bin/bun"
    return 0
  fi
  if [[ -x "$HOME/.local/bun/bin/bun" ]]; then
    printf '%s\n' "$HOME/.local/bun/bin/bun"
    return 0
  fi
  return 1
}

BUN="$(find_bun)" || {
  printf 'transcribe: bun is required but not found\n' >&2
  exit 1
}

exec "$BUN" run "$PROJECT_DIR/src/main.ts" "$@"
